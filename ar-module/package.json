{
  "name": "ar-module",
  "version": "1.0.0",
  "description": "AR visualization module for fashion try-on",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts --exec 'yarn build'",
    "clean": "rm -rf dist",
    "prepublishOnly": "yarn clean && yarn build",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "ar",
    "three.js",
    "mediapipe",
    "fashion",
    "try-on"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mediapipe/pose": "^0.5.1675469404",
    "@tensorflow/tfjs": "^4.17.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/three": "^0.160.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "src"
  ]
}
