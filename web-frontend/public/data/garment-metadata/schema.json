{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "version", "displayName", "width", "height", "anchors"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "number", "minimum": 1 },
    "displayName": { "type": "string" },
    "width": { "type": "number", "minimum": 1 },
    "height": { "type": "number", "minimum": 1 },
    "anchors": {
      "type": "object",
      "required": ["collar_left", "collar_right"],
      "properties": {
        "collar_left": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 1 },
          "minItems": 2,
          "maxItems": 2
        },
        "collar_right": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 1 },
          "minItems": 2,
          "maxItems": 2
        },
        "hem_center": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 1 },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "body_offsets": {
      "type": "object",
      "properties": {
        "neck_drop_ratio": { "type": "number", "default": 0.06 },
        "torso_length_ratio": { "type": "number", "default": 1.05 }
      }
    }
  }
}
