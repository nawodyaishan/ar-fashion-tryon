# API Configuration
API_TITLE="AR Fashion ML API"
API_VERSION="1.0.0"
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ML Models
MODELS_DIR=./models
YOLO_MODEL=yolov8n-seg.pt
POSE_CONFIDENCE_THRESHOLD=0.5
GARMENT_CONFIDENCE_THRESHOLD=0.7

# Performance
ENABLE_GPU=True
BATCH_SIZE=1
MAX_IMAGE_SIZE=1024